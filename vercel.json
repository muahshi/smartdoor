{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.mysmartdoor.in" }],
      "destination": "https://mysmartdoor.in/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/login",          "destination": "/login.html" },
    { "source": "/admin-login",    "destination": "/admin-login.html" },
    { "source": "/app",            "destination": "/app.html" },
    { "source": "/admin",          "destination": "/admin.html" },
    { "source": "/onboarding",     "destination": "/onboarding.html" },
    { "source": "/gate/:path*",    "destination": "/guard.html" },
    { "source": "/society/:path*", "destination": "/society-admin.html" },
    { "source": "/p/:slug",        "destination": "/visitor.html?plate=:slug" },
    { "source": "/pass/:code",     "destination": "/visitor.html?plate=:code" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(self), microphone=()" }
      ]
    },
    {
      "source": "/app.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/admin.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/login.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/admin-login.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/guard.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/society-admin.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/visitor.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/services/:file*",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
